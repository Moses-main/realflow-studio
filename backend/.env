# ========================================================
# BACKEND ENVIRONMENT VARIABLES (Node.js)
# ========================================================

# The port the server will run on (Default: 5000)
PORT=5000

# production or development
NODE_ENV=development

# ⚠️ CRITICAL: The private key of the funded deployer wallet (0xe81e...)
# Must be a 64-character hex string starting with 0x
DEPLOYER_PRIVATE_KEY=cb601f9647fa12dea8081b5bfed574f40f4f41996401ea5901bcb314392e90e9

# RPC URLs for supported networks
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Optional: Pre-deployed contract addresses
MARKETPLACE_FACTORY_ADDRESS=0x895605cfacb5f0d9de464dce03b81df73bd3783c
AVALANCHE_CONTRACT_ADDRESS=0x62f0be8a94f7e348f15f6f373e35ae5c34f7d40f

# API Keys for contract verification
POLYGONSCAN_API_KEY=
SNOWTRACE_API_KEY=

# 🛡️ SECURITY: The URL of your deployed Vercel frontend
# (Used to prevent unauthorized websites from calling your API)
CORS_ORIGIN=https://realflowstudio.vercel.app

# ========================================================
# BACKEND DEPLOYMENT SETTINGS (Render/Railway)
# ========================================================
# Root Directory: backend
# Build Command: npm install
# Start Command: node src/server.js
# ========================================================
