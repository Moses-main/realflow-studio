<file_path>
realflow-studio/.env.example
</file_path>

# Environment Variables Example File for Frontend

# General
NODE_ENV=development

# API URL for the backend
REACT_APP_API_URL=http://localhost:5000

# Wallet connection settings
REACT_APP_WALLET_CONNECT_PROJECT_ID=YOUR_WALLET_CONNECT_PROJECT_ID

# OpenAI API key for AI integrations (if applicable)
REACT_APP_OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# IPFS configuration (if applicable)
REACT_APP_IPFS_PROJECT_ID=YOUR_IPFS_PROJECT_ID
REACT_APP_IPFS_PROJECT_SECRET=YOUR_IPFS_PROJECT_SECRET
